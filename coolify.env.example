# Runtime environment variables for Coolify
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Dashboard login password
ADMIN_PASSWORD=change-this-dashboard-password

# Secret used for gateway API keys
JWT_SECRET=change-this-to-a-long-random-secret

# Chrome extension token
EXTENSION_TOKEN=change-this-extension-token

# Use your public dashboard domain, or * if you explicitly want open CORS
CORS_ORIGINS=https://gateway.example.com

# SQLite database path inside the container
DB_PATH=/data/gateway.db

# Request log retention window in days
LOG_RETENTION_DAYS=30
